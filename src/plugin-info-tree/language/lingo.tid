title: $:/plugins/nikorion/plugin-info-tree/language/lingo
tags: $:/tags/Global

\procedure plugin-info-tree-lingo(title)
\whitespace trim
<$let _lang={{{ [[$:/language]get[text]get[name]else[en-GB]] }}}>
<$transclude $tiddler={{{ [[$:/plugins/nikorion/plugin-info-tree/language/]addsuffix<_lang>addsuffix[/]addsuffix<title>] }}}>
<$transclude $tiddler={{{ [[$:/plugins/nikorion/plugin-info-tree/language/en-GB/]addsuffix<title>] }}}/>
</$transclude>
</$let>
\end

\function plugin-info-tree-lingo-text(title)
[[$:/language]get[text]get[name]else[en-GB]addprefix[$:/plugins/nikorion/plugin-info-tree/language/]addsuffix[/]addsuffix<title>get[text]] :else[[$:/plugins/nikorion/plugin-info-tree/language/en-GB/]addsuffix<title>get[text]] :else<title>
\end
